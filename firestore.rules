rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return isSignedIn() && userProfile().active == true;
    }

    function hasRole(roles) {
      return isActive() && roles.hasAny([userProfile().role]);
    }

    function isString(value) {
      return value is string && value.size() > 0;
    }

    function isNonNegative(value) {
      return value is number && value >= 0;
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || hasRole(['admin']));
      allow create: if false;
      allow update: if hasRole(['admin'])
                    && isString(request.resource.data.email)
                    && isString(request.resource.data.displayName)
                    && request.resource.data.role in ['admin', 'manager', 'sales', 'warehouse']
                    && request.resource.data.active is bool;
      allow delete: if false;
    }

    match /settings/{id} {
      allow read: if isActive();
      allow create, update: if hasRole(['admin']);
      allow delete: if false;
    }

    match /customers/{id} {
      allow read: if isActive();
      allow create: if false;
      allow update: if hasRole(['admin', 'manager', 'sales'])
                    && request.resource.data.balance == resource.data.balance;
      allow delete: if false;
    }

    match /suppliers/{id} {
      allow read: if hasRole(['admin', 'manager', 'warehouse']);
      allow create: if false;
      allow update: if hasRole(['admin', 'manager'])
                    && request.resource.data.balance == resource.data.balance;
      allow delete: if false;
    }

    match /products/{id} {
      allow read: if isActive();
      allow create: if false;
      allow update: if hasRole(['admin', 'manager', 'warehouse'])
                    && request.resource.data.stock == resource.data.stock
                    && isNonNegative(request.resource.data.unitPrice);
      allow delete: if false;
    }

    match /sales_orders/{id} {
      allow read: if isActive();
      allow create, update: if false;
      allow delete: if false;
    }

    match /delivery_orders/{id} {
      allow read: if isActive();
      allow create: if false;
      allow update: if hasRole(['admin', 'manager', 'sales', 'warehouse'])
                    && resource.data.status == 'draft'
                    && request.resource.data.status == 'draft'
                    && request.resource.data.doNumber == resource.data.doNumber;
      allow delete: if false;
    }

    match /purchase_orders/{id} {
      allow read: if hasRole(['admin', 'manager', 'warehouse']);
      allow create, update: if false;
      allow delete: if false;
    }

    match /invoices/{id} {
      allow read: if hasRole(['admin', 'manager', 'sales']);
      allow create: if false;
      allow update: if hasRole(['admin', 'manager', 'sales'])
                    && resource.data.status == 'draft'
                    && request.resource.data.status == 'draft'
                    && request.resource.data.invoiceNumber == resource.data.invoiceNumber
                    && request.resource.data.amountPaid == resource.data.amountPaid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                      'type',
                      'approvalStatus',
                      'approvedBy',
                      'approvedAt'
                    ]);
      allow delete: if false;
    }

    match /payments/{id} {
      allow read: if hasRole(['admin', 'manager', 'sales']);
      allow create, update, delete: if false;
    }

    match /supplier_payments/{id} {
      allow read: if hasRole(['admin', 'manager']);
      allow create, update, delete: if false;
    }

    match /stock_movements/{id} {
      allow read: if hasRole(['admin', 'manager', 'warehouse']);
      allow create, update, delete: if false;
    }

    match /po_allocations/{id} {
      allow read: if isActive();
      allow write: if false;
    }

    match /activity_logs/{id} {
      allow read: if hasRole(['admin', 'manager']);
      allow create, update, delete: if false;
    }

    match /counters/{name} {
      allow read: if isActive();
      allow write: if false;
    }
  }
}
