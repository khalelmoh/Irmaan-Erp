    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "firebase-admin": "^14.0.0",
    "firebase-tools": "^15.22.0",
    "postcss": "8.5.15",
