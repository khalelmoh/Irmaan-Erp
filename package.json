{
  "name": "irmaan-erp",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "8.5.15",
    "protobufjs": "7.6.4"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.mjs,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/business-logic.test.ts",
    "test:rules": "node --import tsx --test tests/firestore-rules.test.ts",
    "test:rules:emulator": "firebase emulators:exec --project irmaan-erp-test --only firestore \"npm run test:rules\"",
    "check": "npm run typecheck && npm run lint && npm run build",
    "functions:build": "npm --prefix functions run build",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.2",
